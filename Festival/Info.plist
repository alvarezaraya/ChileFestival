<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Opt-in a ProMotion: sin esta llave, iOS limita a 60 Hz las animaciones
	     dirigidas por la app (TimelineView/CADisplayLink) en iPhone, aunque el
	     panel sea de 120 Hz. Xcode fusiona este plist con el generado. -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!-- Los previews de 30 s (AVQueuePlayer propio) siguen sonando con la
	     pantalla bloqueada o la app en segundo plano. La reproducción completa
	     no lo necesita (suena en la app Música, proceso aparte). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
</dict>
</plist>
